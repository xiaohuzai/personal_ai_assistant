# ── 飞书机器人 ──────────────────────────────────────────────
# 在飞书开放平台（https://open.feishu.cn）创建企业自建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM Provider ────────────────────────────────────────────
# 二选一：直连 Anthropic 或走兼容代理

# 方式 A：直连 Anthropic（填写 API Key，注释掉方式 B 的三行）
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# 方式 B：兼容 Anthropic 格式的代理网关
ANTHROPIC_BASE_URL=https://your-gateway.example.com
ANTHROPIC_AUTH_TOKEN=your-gateway-token
ANTHROPIC_API_KEY=

# 网关自定义模型别名（不填则使用网关默认值）
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4.6
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4.6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4.6

# 禁用实验性 beta（使用代理网关时通常需要设为 1）
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# ── 助理配置 ────────────────────────────────────────────────
# Agent 工作目录（建议直接用项目内的 workspace/，无需修改）
ASSISTANT_CWD=/path/to/your/repo/workspace

# 用户标识，写入 system prompt，让 Agent 知道在为谁服务
AGENT_OWNER=your_name

# 日志级别（DEBUG / INFO / WARNING，默认 INFO）
# LOG_LEVEL=INFO

# ── lark-cli（可选）────────────────────────────────────────────
# lark-cli 用于让 Agent 访问飞书空间（日历、文档、消息等）
# 安装：npm install -g @larksuite/cli  （需要 Node.js 16+）
# 配置参考：https://github.com/larksuite/cli
#
# ⚠️  重要：lark-cli 绑定的飞书应用必须与上方 FEISHU_APP_ID / FEISHU_APP_SECRET 一致！
#    在新服务器上按顺序执行：
#
#    1. 初始化应用配置（与飞书机器人使用同一套 App ID / Secret）：
#       lark-cli config init --app-id <FEISHU_APP_ID> --app-secret-stdin --brand feishu
#
#    2. 授权个人账号（用户身份访问飞书，每台新服务器都需执行一次）：
#       lark-cli auth login
#
# 启动时会自动搜索 nvm/npm 全局路径，通常无需配置。
# 若安装在非标准位置，可显式指定 bin 目录：
# LARK_CLI_BIN_DIR=/path/to/your/node/bin
